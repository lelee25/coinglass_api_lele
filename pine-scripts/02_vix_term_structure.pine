//@version=6
//
// =============================================================================
// Pine Script #2 — VIX TERM STRUCTURE REGIME DETECTOR
// =============================================================================
// Author: gex-agentkit team (lelee25)
// Last update: 2026-05-08
// Pine version: v6
//
// PURPOSE:
//   Calcola lo slope della curva VIX (VIX9D / VIX / VIX3M / VIX6M) come
//   segnale CONTRARIAN macro. Backwardation deep (VIX > VIX3M con ratio
//   alto) marca FEAR EXTREME storicamente seguito da rally equity 5-10gg.
//   Per crypto via macro-correlation: backwardation → V-bottom alta probabilità.
//
// EDGE DOCUMENTATO:
//   - Johnson 2017 JFQA "Risk Premia and the VIX Term Structure"
//     https://www.travislakejohnson.com/pdfs/Johnson%20VIXTS%202017%20(JFQA).pdf
//     Peer-reviewed: ratio>1.10 + rolling-over hook → forward 5-10d S&P
//     positive return statisticamente significativo.
//   - Macrosynergy "VIX term structure as a trading signal"
//     https://macrosynergy.com/research/vix-term-structure-as-a-trading-signal/
//   - Cboe "Inside Volatility Trading: Is VIX Backwardation Necessarily a
//     Sign of a Future Down Market?" (no, è il contrario)
//   - Hit rate: ~62-65% su forward 5-10d S&P quando ratio > 1.10 + rollover
//   - Lead time: 2-7 giorni
//
// CROSS-CHAIN per gex-agentkit:
//   Combinato con Coinbase Premium (CoinGlass) + funding negative crypto:
//   se backwardation + premium positivo + funding < 0 → V-bottom altissimo edge.
//   Combinato con DVOL Deribit (script #5) → vol regime cross-asset completo.
//
// TICKERS VALIDATED 2026-05-08:
//   CBOE:VIX9D, CBOE:VIX, CBOE:VIX3M, CBOE:VIX6M
//
// =============================================================================

indicator("VIX Term Structure [gex-agentkit]",
  shorttitle="VIX-TS",
  overlay=false,
  format=format.price,
  precision=3)

// =============================================================================
// INPUTS
// =============================================================================
ratio_thr     = input.float(1.10, "Backwardation alert ratio (VIX/VIX3M)",  minval=1.0, maxval=1.5, step=0.01, group="Thresholds")
deep_thr      = input.float(1.20, "Deep backwardation ratio",                minval=1.05, maxval=1.5, step=0.01, group="Thresholds")
contango_thr  = input.float(0.90, "Strong contango ratio",                   minval=0.7, maxval=0.95, step=0.01, group="Thresholds",
                              tooltip="VIX/VIX3M < 0.90 = complacency strong, contrarian risk-off potenziale")
hook_lookback = input.int(3, "Bars lookback per rollover hook detection",    minval=1, maxval=10, group="Thresholds")
secret        = input.string("REPLACE_WITH_SECRET", "Webhook secret token",  group="Webhook security")

// =============================================================================
// FETCH VIX TERM STRUCTURE
// =============================================================================
// VIX9D: 9-day expectation
// VIX:   30-day (the standard)
// VIX3M: 90-day (3 months)
// VIX6M: 180-day (6 months)
//
// In normale contango: VIX9D < VIX < VIX3M < VIX6M
// In backwardation:    VIX9D > VIX > VIX3M (front > back)

vix9d = request.security("CBOE:VIX9D", timeframe.period, close, lookahead=barmerge.lookahead_off)
vix   = request.security("CBOE:VIX",   timeframe.period, close, lookahead=barmerge.lookahead_off)
vix3m = request.security("CBOE:VIX3M", timeframe.period, close, lookahead=barmerge.lookahead_off)
vix6m = request.security("CBOE:VIX6M", timeframe.period, close, lookahead=barmerge.lookahead_off)

// =============================================================================
// SLOPE METRICS
// =============================================================================
// Primary metric: VIX/VIX3M ratio (standard term structure measure)
ratio_v_3m = vix / vix3m

// Secondary: VIX9D/VIX (ultra-short term stress)
ratio_9d_v = vix9d / vix

// Tertiary: VIX3M/VIX6M (long-term term structure shape)
ratio_3m_6m = vix3m / vix6m

// Composite slope: weighted average (simple to interpret)
//   negative = contango (normal calm), positive = backwardation (stress)
ts_score = ((ratio_v_3m - 1) * 0.5) + ((ratio_9d_v - 1) * 0.3) + ((ratio_3m_6m - 1) * 0.2)

// =============================================================================
// REGIME CLASSIFICATION
// =============================================================================
// 5 stati:
//   strong_contango  (< contango_thr)        → COMPLACENCY, contrarian risk-off
//   contango         ([contango_thr, 1.0))   → NORMAL calm
//   neutral          ([1.0, ratio_thr))      → in transizione
//   backwardation    ([ratio_thr, deep_thr)) → STRESS, contrarian risk-on
//   deep_backwardation (>= deep_thr)         → PANIC, V-bottom setup

regime = ratio_v_3m >= deep_thr     ? "deep_backwardation" :
         ratio_v_3m >= ratio_thr    ? "backwardation"      :
         ratio_v_3m >= 1.0          ? "neutral"            :
         ratio_v_3m >= contango_thr ? "contango"           :
                                       "strong_contango"

regime_score = ratio_v_3m >= deep_thr     ?  2 :
               ratio_v_3m >= ratio_thr    ?  1 :
               ratio_v_3m >= 1.0          ?  0 :
               ratio_v_3m >= contango_thr ? -1 :
                                            -2

// =============================================================================
// ROLLOVER HOOK DETECTION (the real alpha trigger)
// =============================================================================
// "Hook" = ratio era in backwardation peak ed inizia a declinare.
// Storicamente questo "rollover" precede il rally 5-10gg.

prev_max = ta.highest(ratio_v_3m, hook_lookback)
hook_down = ratio_v_3m < prev_max[1] and ratio_v_3m[1] >= ratio_thr and ratio_v_3m < ratio_v_3m[1]
hook_signal = hook_down and ratio_v_3m[1] >= ratio_thr

// =============================================================================
// PLOT
// =============================================================================
ratio_color = regime_score >= 2 ? color.red :
              regime_score == 1 ? color.orange :
              regime_score == 0 ? color.gray :
              regime_score == -1 ? color.green :
                                    color.lime

plot(ratio_v_3m, "VIX/VIX3M", color=ratio_color, linewidth=2)
plot(ratio_9d_v, "VIX9D/VIX", color=color.new(color.purple, 30), linewidth=1)
plot(ratio_3m_6m, "VIX3M/VIX6M", color=color.new(color.blue, 30), linewidth=1)

hline(1.0, "Neutral (1.0)", color=color.gray)
hline(ratio_thr, "Backwardation", color=color.orange, linestyle=hline.style_dashed)
hline(deep_thr, "Deep BW", color=color.red, linestyle=hline.style_dashed)
hline(contango_thr, "Strong contango", color=color.lime, linestyle=hline.style_dashed)

// Hook marker
plotshape(hook_signal, "Hook (rollover)", style=shape.triangledown,
          location=location.top, color=color.lime, size=size.normal)

// Status table
if barstate.islast
    var table info = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 70))
    table.cell(info, 0, 0, "VIX9D",         text_color=color.white)
    table.cell(info, 1, 0, str.tostring(vix9d,  "#.##"), text_color=color.white)
    table.cell(info, 0, 1, "VIX",           text_color=color.white)
    table.cell(info, 1, 1, str.tostring(vix,    "#.##"), text_color=color.white)
    table.cell(info, 0, 2, "VIX3M",         text_color=color.white)
    table.cell(info, 1, 2, str.tostring(vix3m,  "#.##"), text_color=color.white)
    table.cell(info, 0, 3, "VIX6M",         text_color=color.white)
    table.cell(info, 1, 3, str.tostring(vix6m,  "#.##"), text_color=color.white)
    table.cell(info, 0, 4, "VIX/VIX3M",     text_color=color.white)
    table.cell(info, 1, 4, str.tostring(ratio_v_3m, "#.###"), text_color=ratio_color)
    table.cell(info, 0, 5, "Regime",        text_color=color.white)
    table.cell(info, 1, 5, regime,          text_color=ratio_color)
    table.cell(info, 0, 6, "Hook?",         text_color=color.white)
    table.cell(info, 1, 6, hook_signal ? "YES (long bias)" : "no", text_color=hook_signal ? color.lime : color.gray)

// =============================================================================
// WEBHOOK ALERTS
// =============================================================================

// Alert 1: regime change (any transition between 5 states)
prev_regime = regime[1]
if barstate.isconfirmed and regime != prev_regime
    msg_regime = '{' +
      '"event":"vix_ts_regime_change",' +
      '"timeframe":"' + timeframe.period + '",' +
      '"regime":"' + regime + '",' +
      '"prev_regime":"' + prev_regime + '",' +
      '"regime_score":' + str.tostring(regime_score) + ',' +
      '"vix":' + str.tostring(vix, "#.##") + ',' +
      '"vix9d":' + str.tostring(vix9d, "#.##") + ',' +
      '"vix3m":' + str.tostring(vix3m, "#.##") + ',' +
      '"vix6m":' + str.tostring(vix6m, "#.##") + ',' +
      '"ratio_vix_vix3m":' + str.tostring(ratio_v_3m, "#.####") + ',' +
      '"ts_composite_score":' + str.tostring(ts_score, "#.####") + ',' +
      '"ts":"' + str.format_time(time, "yyyy-MM-ddTHH:mm:ssZ", "UTC") + '",' +
      '"secret":"' + secret + '"' +
    '}'
    alert(msg_regime, alert.freq_once_per_bar_close)

// Alert 2: rollover hook (THE alpha signal — contrarian long bias)
if barstate.isconfirmed and hook_signal
    msg_hook = '{' +
      '"event":"vix_ts_rollover_hook",' +
      '"timeframe":"' + timeframe.period + '",' +
      '"signal":"contrarian_risk_on",' +
      '"regime":"' + regime + '",' +
      '"vix":' + str.tostring(vix, "#.##") + ',' +
      '"ratio_vix_vix3m":' + str.tostring(ratio_v_3m, "#.####") + ',' +
      '"prior_peak_ratio":' + str.tostring(prev_max[1], "#.####") + ',' +
      '"forward_5d_bias":"long_equity_long_crypto",' +
      '"confidence":0.65,' +
      '"academic_source":"Johnson_2017_JFQA",' +
      '"ts":"' + str.format_time(time, "yyyy-MM-ddTHH:mm:ssZ", "UTC") + '",' +
      '"secret":"' + secret + '"' +
    '}'
    alert(msg_hook, alert.freq_once_per_bar_close)
