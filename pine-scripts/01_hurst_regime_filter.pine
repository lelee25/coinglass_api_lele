//@version=6
//
// =============================================================================
// Pine Script #1 — HURST EXPONENT REGIME FILTER
// =============================================================================
// Author: gex-agentkit team (lelee25)
// Last update: 2026-05-08
// Pine version: v6 (validated against tradingview.com/pine-script-reference/v6/)
//
// PURPOSE:
//   Master switch ortogonale per il sistema multi-agent gex-agentkit.
//   Calcola Hurst Exponent rolling via R/S analysis e classifica il
//   regime di mercato in: TRENDING (H>0.55), MEAN-REVERTING (H<0.45),
//   RANDOM (0.45-0.55, no edge → stand down).
//
//   Permette agli agent execution di filtrare strategie:
//     - Momentum agent ON when H > 0.55
//     - Mean-reversion agent ON when H < 0.45
//     - All agents idle when H in [0.45, 0.55]
//
// EDGE DOCUMENTATO:
//   - Macrosynergy: "Detecting trends and mean reversion with the Hurst exponent"
//     https://macrosynergy.com/research/detecting-trends-and-mean-reversion-with-the-hurst-exponent/
//   - Strategie momentum filtrate da H>0.55 hanno Sharpe ~+0.4 vs unfiltered
//   - PhenLabs HEAF (Hurst Exponent Adaptive Filter) reference su TV
//
// WEBHOOK INTEGRATION (gex-agentkit):
//   Endpoint: POST {server}/api/tv/webhook
//   Authentication: secret token in body (no native auth in TV)
//   Trigger: regime change only (event-driven, not periodic)
//
// =============================================================================

indicator("Hurst Regime Filter [gex-agentkit]",
  shorttitle="HURST",
  overlay=false,
  max_bars_back=2000)

// =============================================================================
// INPUTS
// =============================================================================
length      = input.int(100, "Lookback bars",      minval=20,  maxval=500,  group="Hurst calculation")
trend_thr   = input.float(0.55, "Trending threshold",  minval=0.5, maxval=0.7, step=0.01, group="Regime classification")
mean_thr    = input.float(0.45, "Mean-rev threshold",  minval=0.3, maxval=0.5, step=0.01, group="Regime classification")
stable_bars = input.int(3, "Bars to confirm regime", minval=1, maxval=10, group="Regime classification",
                          tooltip="Numero di bar consecutive nello stesso regime prima di emettere webhook")
secret      = input.string("REPLACE_WITH_SECRET", "Webhook secret token", group="Webhook security")
asset_tag   = input.string("BTCUSDT", "Asset tag (per agentkit routing)", group="Webhook security")

// =============================================================================
// HURST EXPONENT — R/S ANALYSIS
// =============================================================================
// Hurst Exponent calcolato via Rescaled Range (R/S) analysis.
// H ∈ [0, 1]:
//   H = 0.5  → random walk (Brownian, no predictability)
//   H > 0.5  → persistent (trending behavior)
//   H < 0.5  → anti-persistent (mean-reverting)
// Reference: Hurst (1951), Mandelbrot & Wallis (1969)

// Step 1: log returns (più stazionari del raw price)
ret = math.log(close / close[1])

// Step 2: rolling mean
mean_ret = ta.sma(ret, length)

// Step 3: cumulative deviation from mean (Y_t = sum(ret - mean))
//         calcolato come array per la finestra rolling
calc_hurst(simple int len) =>
    var array<float> deviations = array.new<float>()
    array.clear(deviations)

    // Build deviation series within lookback window
    for i = 0 to len - 1
        ret_i = math.log(close[i] / close[i + 1])
        array.unshift(deviations, ret_i)

    // Mean of returns in window
    mean_dev = array.avg(deviations)

    // Cumulative deviation Y_t
    var array<float> cumdev = array.new<float>()
    array.clear(cumdev)
    cum = 0.0
    for i = 0 to len - 1
        cum += array.get(deviations, i) - mean_dev
        array.push(cumdev, cum)

    // Range: max - min of cumulative deviation
    range_R = array.max(cumdev) - array.min(cumdev)

    // Standard deviation of returns
    std_S = array.stdev(deviations)

    // R/S ratio
    rs = std_S > 0 ? range_R / std_S : 1.0

    // Hurst: log(R/S) / log(N)
    hurst = math.log(rs) / math.log(len)
    hurst

hurst = calc_hurst(length)

// =============================================================================
// REGIME CLASSIFICATION + SMOOTHING
// =============================================================================
raw_regime = hurst > trend_thr ? 1 : (hurst < mean_thr ? -1 : 0)
//   1 = TRENDING (momentum agent ON)
//  -1 = MEAN-REVERTING (mean-rev agent ON)
//   0 = RANDOM (stand down)

// Persistence check: regime confermato solo dopo N bar consecutivi
var int regime_age = 0
var int current_regime = 0
var int prev_committed_regime = 0

if raw_regime == current_regime
    regime_age += 1
else
    current_regime := raw_regime
    regime_age := 1

// Commit regime change quando età >= stable_bars
committed_regime = regime_age >= stable_bars ? current_regime : prev_committed_regime
regime_changed = committed_regime != prev_committed_regime[1] and barstate.isconfirmed

if barstate.isconfirmed
    prev_committed_regime := committed_regime

// =============================================================================
// PLOT
// =============================================================================
hurst_color = committed_regime == 1 ? color.green : (committed_regime == -1 ? color.red : color.gray)
plot(hurst, "Hurst Exponent", color=hurst_color, linewidth=2)
hline(0.5, "Neutral (H=0.5)", color=color.gray, linestyle=hline.style_dashed)
hline(trend_thr, "Trend threshold", color=color.green, linestyle=hline.style_dotted)
hline(mean_thr, "Mean-rev threshold", color=color.red, linestyle=hline.style_dotted)

// Background coloring per regime visivo
bgcolor(committed_regime == 1 ? color.new(color.green, 90) :
        committed_regime == -1 ? color.new(color.red, 90) : na)

// Status table
if barstate.islast
    var table info = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 70))
    regime_label = committed_regime == 1 ? "TRENDING" :
                   committed_regime == -1 ? "MEAN-REV" : "RANDOM"
    table.cell(info, 0, 0, "Hurst",    text_color=color.white)
    table.cell(info, 1, 0, str.tostring(hurst, "#.###"), text_color=color.white)
    table.cell(info, 0, 1, "Regime",   text_color=color.white)
    table.cell(info, 1, 1, regime_label, text_color=hurst_color)
    table.cell(info, 0, 2, "Age",      text_color=color.white)
    table.cell(info, 1, 2, str.tostring(regime_age) + " bars", text_color=color.white)
    table.cell(info, 0, 3, "Length",   text_color=color.white)
    table.cell(info, 1, 3, str.tostring(length), text_color=color.white)

// =============================================================================
// WEBHOOK ALERT (event-driven on regime change)
// =============================================================================
//
// Setup TradingView side:
//   1. Save this indicator on chart (BTC/USDT 1h or 4h recommended)
//   2. Right-click → "Add Alert..." (or Alt+A)
//   3. Condition: "Hurst Regime Filter" + "Any alert() function call"
//   4. Webhook URL: https://your-server.com/api/tv/webhook
//   5. Message: leave empty (script provides message via alert())
//
// Backend (gex-agentkit) parsing:
//   POST body = JSON con campi documentati sotto
//   Validate: secret == expected_token, ts < 60s old
//   Route to: macro-regime-monitor agent

regime_label_str = committed_regime == 1 ? "trending" :
                   committed_regime == -1 ? "mean_reverting" : "random"
prev_regime_str = prev_committed_regime[1] == 1 ? "trending" :
                  prev_committed_regime[1] == -1 ? "mean_reverting" : "random"

if regime_changed
    msg = '{' +
      '"event":"hurst_regime_change",' +
      '"asset":"' + asset_tag + '",' +
      '"timeframe":"' + timeframe.period + '",' +
      '"regime":"' + regime_label_str + '",' +
      '"prev_regime":"' + prev_regime_str + '",' +
      '"hurst":' + str.tostring(hurst, "#.####") + ',' +
      '"length":' + str.tostring(length) + ',' +
      '"price":' + str.tostring(close, "#.##") + ',' +
      '"ts":"' + str.format_time(time, "yyyy-MM-ddTHH:mm:ssZ", "UTC") + '",' +
      '"secret":"' + secret + '"' +
    '}'
    alert(msg, alert.freq_once_per_bar_close)
